generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Business {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  phone     String?
  email     String?
  timezone  String   @default("America/Panama")
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  chairs      Chair[]
  services    Service[]
  customers   Customer[]
  bookings    Booking[]
  invitations Invitation[]
}

model User {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  chair    Chair?
}

model Chair {
  id          String   @id @default(cuid())
  businessId  String
  userId      String?  @unique
  name        String
  description String?
  avatarUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business      Business        @relation(fields: [businessId], references: [id])
  user          User?           @relation(fields: [userId], references: [id])
  chairServices ChairService[]
  schedules     ChairSchedule[]
  bookings      Booking[]
}

model ChairSchedule {
  id        String  @id @default(cuid())
  chairId   String
  dayOfWeek Int     // 0=domingo … 6=sábado
  openTime  String  // "09:00"
  closeTime String  // "18:00"
  isActive  Boolean @default(true)

  chair Chair @relation(fields: [chairId], references: [id])

  @@unique([chairId, dayOfWeek])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  description     String?
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)
  color           String   @default("#185FA5")
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id])
  chairServices ChairService[]
  bookings      Booking[]
}

model ChairService {
  id        String @id @default(cuid())
  chairId   String
  serviceId String

  chair   Chair   @relation(fields: [chairId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([chairId, serviceId])
}

model Customer {
  id         String   @id @default(cuid())
  businessId String
  name       String
  email      String?
  phone      String?
  createdAt  DateTime @default(now())

  business Business  @relation(fields: [businessId], references: [id])
  bookings  Booking[]

  @@unique([businessId, email])
}

model Invitation {
  id         String    @id @default(cuid())
  businessId String
  code       String    @unique
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model Booking {
  id         String        @id @default(cuid())
  businessId String
  chairId    String
  serviceId  String
  customerId String
  startTime  DateTime
  endTime    DateTime
  status     BookingStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id])
  chair    Chair    @relation(fields: [chairId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}
